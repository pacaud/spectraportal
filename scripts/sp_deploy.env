REMOTE="root@100.121.30.60"

# Primary public docs/dev site
WEBROOT_DEV="/var/www/spectraportal.dev"

# Backward-compat fallback if older scripts still reference WEBROOT_DOCS
WEBROOT_DOCS="${WEBROOT_DEV}"
WEBROOT_DEV_BROWSE="${WEBROOT_DEV}/browse"

WEBROOT_FRAMEWORK="/var/www/framework.spectraportal.dev"
WEBROOT_CDN="/var/www/cdn.spectraportal.dev"
WEBROOT_ASSETS="/var/www/assets.spectraportal.dev"
WEBROOT_GATE="/var/www/gate.spectraportal.dev"

# Private editable workspace roots
WORKSPACE_ROOT="/srv/spectraportal/workspace/site"
WORKSPACE_GATE_DRAFTS="$WORKSPACE_ROOT/gate/drafts"

# Private source/module roots on the droplet
SRV_ROOT="/srv/spectraportal"
SRV_BOOT="$SRV_ROOT/boot"
SRV_CHAT_CENTER="$SRV_ROOT/chat_center"
SRV_CORE="$SRV_ROOT/core"

# Gate subpath publish for Hollowverse readable/public endpoint
WEBROOT_GATE_HOLLOWVERSE="${WEBROOT_GATE}/hollowverse"

# Optional standalone public Hollowverse site
WEBROOT_HOLLOWVERSE="/var/www/hollowverse.studio"

# Shared private source/module root for Hollowverse library surface
SRV_HOLLOWVERSE="$SRV_ROOT/hollowverse"
